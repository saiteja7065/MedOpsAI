# Frontend (Vite) — copy this file to .env and fill in your Supabase project values.
# Find these under Supabase Dashboard > Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --------------------------------------------------------------------------
# GROQ_API_KEY is NOT read by the frontend. It must be set as a Supabase Edge
# Function secret instead (never exposed to the browser):
#
#   supabase secrets set GROQ_API_KEY=your-groq-key
#
# Get a free key at https://console.groq.com/keys
# Optional: override the model (defaults to llama-3.3-70b-versatile)
#   supabase secrets set GROQ_MODEL=llama-3.3-70b-versatile
# --------------------------------------------------------------------------
